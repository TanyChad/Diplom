#Область СлужебныеПроцедурыИФункции

&НаСервере
Процедура ЗаполнитьНаСервере() 
	
	ОбъектТек = РеквизитФормыВЗначение("Объект"); 
	ОбъектТек.ЗаполнитьВыплаты();
	
	ЗначениеВРеквизитФормы(ОбъектТек, "Объект");
КонецПроцедуры
